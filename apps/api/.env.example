# ShortFlix API Gateway environment.
# Local dev: SQLite via absolute path (Prisma does NOT expand ~).
# Replace /ABS/PATH/TO/HOME with your real $HOME.
DATABASE_URL=file:/ABS/PATH/TO/HOME/.preview-forge/shortflix/dev.db

# JWT signing key (RS256 in prod via Cloud KMS; HS256 secret OK for local).
JWT_ALG=HS256
JWT_SECRET=local-dev-only-replace-me-32bytes-min
JWT_ISSUER=shortflix
JWT_AUDIENCE=shortflix-pwa
JWT_TTL_SECONDS=2592000

# Cookie config.
SESSION_COOKIE_NAME=sf_session
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false

# Google OAuth (PKCE — server validates the code+verifier coming from the PWA).
GOOGLE_OAUTH_CLIENT_ID=replace.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=replace
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Agent service base URLs (Python/ADK services run separately — see HTTP_A2A stubs).
ORCHESTRATOR_BASE_URL=http://localhost:8081
CURATOR_BASE_URL=http://localhost:8082
UNIFIED_SEARCH_BASE_URL=http://localhost:8083
TREND_SAFETY_BASE_URL=http://localhost:8084

# MCP service base URLs (Python services run separately).
YT_SHORTS_MCP_BASE_URL=http://localhost:8091
IG_REELS_MCP_BASE_URL=http://localhost:8092
TIKTOK_MCP_BASE_URL=http://localhost:8093

# Service identity (Cloud Run prod uses Google-signed identity tokens; local stub).
SERVICE_ACCOUNT_AUDIENCE=local-dev
SERVICE_ACCOUNT_TOKEN=local-dev-token

# Server.
PORT=8081
NODE_ENV=development

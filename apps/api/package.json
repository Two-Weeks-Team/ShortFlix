{
  "name": "@shortflix/api",
  "version": "0.1.1",
  "private": true,
  "description": "ShortFlix API Gateway (NestJS + @nestia + typia). REST front-door for the PWA; routes to ADK agent services via HTTP A2A.",
  "license": "Apache-2.0",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "build:sdk": "nestia sdk",
    "build:swagger": "nestia swagger",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema=../../prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=../../prisma/schema.prisma",
    "prisma:db:push": "prisma db push --schema=../../prisma/schema.prisma"
  },
  "dependencies": {
    "@nestia/core": "^4.5.0",
    "@nestia/fetcher": "^4.5.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/client": "^5.22.0",
    "cookie-parser": "^1.4.7",
    "google-auth-library": "^9.14.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typia": "^7.6.0",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@nestia/sdk": "^4.5.0",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.2.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20.10"
  }
}

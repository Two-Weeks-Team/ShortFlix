# ============================================================================
# ShortFlix — .env.example
# ============================================================================
# This file documents EVERY env var across the 8 services. It is checked in.
#
# DO NOT commit a real .env file. Production secrets live in Google Secret Manager
# (see deploy/iam.yaml `secrets:` section). Local-dev values can go in `.env.local`
# (gitignored) — copy this file as the starting point.
#
# Per user policy: this repository's actual `.env` will NEVER be modified by
# automation without explicit user instruction.
#
# Layering (precedence: highest → lowest):
#   1. Cloud Run env (set via deploy/services/*.yaml + --set-secrets)
#   2. Local apps/<svc>/.env.local
#   3. This file (defaults / documentation)
# ============================================================================


# ---------- Shared / Project ----------
GCP_PROJECT_ID=shortflix
GCP_REGION=asia-northeast3
NODE_ENV=development


# ============================================================================
# apps/web — Next.js PWA (port 3000)
# ============================================================================
# Build-time public env (exposed to browser) — must be NEXT_PUBLIC_* prefix.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_BRAND_NAME=ShortFlix
NEXT_TELEMETRY_DISABLED=1


# ============================================================================
# apps/api — NestJS gateway (port 3001)
# ============================================================================
PORT=3001
LOG_LEVEL=info

# Database (Prisma). For local dev use SQLite; in Cloud Run use Cloud SQL Postgres or Firestore-only.
DATABASE_URL=file:./apps/api/dev.db

# Firestore (preferred user-state store per spec).
FIRESTORE_PROJECT_ID=shortflix
# Path to ADC for local dev. In Cloud Run, identity is automatic via the SA.
GOOGLE_APPLICATION_CREDENTIALS=./.gcp/adc.json

# OAuth (MD-06): Google ID only.
# Values come from Secret Manager in production; placeholder here.
GOOGLE_OAUTH_CLIENT_ID=__REPLACE_VIA_SECRET_MANAGER__
GOOGLE_OAUTH_CLIENT_SECRET=__REPLACE_VIA_SECRET_MANAGER__
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# JWT signing (HS256, ≥256-bit). Production: Secret Manager `JWT_SIGNING_KEY`.
JWT_SIGNING_KEY=__REPLACE_VIA_SECRET_MANAGER__
JWT_ISSUER=shortflix-api
JWT_AUDIENCE=shortflix-web
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# A2A — orchestrator URL the API calls.
ORCHESTRATOR_URL=http://localhost:8081

# CORS (PWA origin).
CORS_ALLOWED_ORIGIN=http://localhost:3000


# ============================================================================
# agents/orchestrator — Python ADK (port 8081)
# ============================================================================
PORT=8081
AGENT_NAME=orchestrator
VERTEX_PROJECT=shortflix
VERTEX_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

CURATOR_URL=http://localhost:8082
SEARCH_URL=http://localhost:8083
TREND_SAFETY_URL=http://localhost:8084

OTEL_EXPORTER_OTLP_ENDPOINT=https://cloudtrace.googleapis.com
OTEL_SERVICE_NAME=orchestrator


# ============================================================================
# agents/curator — Python ADK (port 8082)
# ============================================================================
# (PORT/AGENT_NAME shown again for clarity; in practice each service has its own .env)
# PORT=8082
# AGENT_NAME=curator
MCP_YT_URL=http://localhost:8090
MCP_IG_URL=http://localhost:8091
MCP_TT_URL=http://localhost:8092


# ============================================================================
# agents/search — Python ADK (port 8083)
# ============================================================================
# PORT=8083
# AGENT_NAME=search


# ============================================================================
# agents/trend-safety — Python ADK (port 8084)
# ============================================================================
# PORT=8084
# AGENT_NAME=trend-safety
# Uses Vertex AI Gemini ONLY. No external LLM endpoints (MD-03 R2).


# ============================================================================
# agents/mcp-yt | mcp-ig | mcp-tt — Node MCP servers (ports 8090-8092)
# ============================================================================
# Each MCP service has its OWN RapidAPI key (separation of concerns).
RAPIDAPI_KEY_YT=__REPLACE_VIA_SECRET_MANAGER__
RAPIDAPI_HOST_YT=youtube-v31.p.rapidapi.com

RAPIDAPI_KEY_IG=__REPLACE_VIA_SECRET_MANAGER__
RAPIDAPI_HOST_IG=instagram-scraper-api2.p.rapidapi.com

RAPIDAPI_KEY_TT=__REPLACE_VIA_SECRET_MANAGER__
RAPIDAPI_HOST_TT=tiktok-scraper7.p.rapidapi.com


# ============================================================================
# CI/CD (GitHub Actions secrets — set in repo settings, NOT here)
# ============================================================================
# GCP_WIF_PROVIDER          — projects/.../providers/github (Workload Identity Federation)
# GCP_DEPLOYER_SA           — sa-cloudbuild-deployer@shortflix.iam.gserviceaccount.com
# NEXT_PUBLIC_API_BASE_URL  — runtime URL for the deployed API (baked at build time)
